{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "chunsa/ai-profile.schema.json", "title": "ai-profile v1",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "id", "display_name_key", "personality", "difficulty", "strategic_weights_bp", "utility_curves", "tactical_behaviors", "difficulty_params", "performance_lod", "provenance"],
  "properties": {
    "schema_version": {"const": 1}, "id": {"$ref": "common.schema.json#/$defs/record_id"}, "display_name_key": {"$ref": "common.schema.json#/$defs/localization_key"}, "personality": {"enum": ["trader", "warrior", "technologist", "balanced"]}, "difficulty": {"enum": ["apprentice", "normal", "hard", "brutal"]},
    "strategic_weights_bp": {"type": "object", "additionalProperties": false, "required": ["economy_focus_bp", "military_focus_bp", "tech_focus_bp", "expansion_aggressiveness_bp", "risk_tolerance_bp", "diplomacy_openness_bp"], "properties": {"economy_focus_bp": {"type": "integer", "minimum": 0, "maximum": 10000}, "military_focus_bp": {"type": "integer", "minimum": 0, "maximum": 10000}, "tech_focus_bp": {"type": "integer", "minimum": 0, "maximum": 10000}, "expansion_aggressiveness_bp": {"type": "integer", "minimum": 0, "maximum": 10000}, "risk_tolerance_bp": {"type": "integer", "minimum": 0, "maximum": 10000}, "diplomacy_openness_bp": {"type": "integer", "minimum": 0, "maximum": 10000}}},
    "utility_curves": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["consideration", "points"], "properties": {"consideration": {"$ref": "common.schema.json#/$defs/snake_tag"}, "points": {"type": "array", "minItems": 2, "maxItems": 16, "items": {"type": "object", "additionalProperties": false, "required": ["input_bp", "output_bp"], "properties": {"input_bp": {"type": "integer", "minimum": 0, "maximum": 10000}, "output_bp": {"type": "integer", "minimum": 0, "maximum": 10000}}}}}}},
    "tactical_behaviors": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["group_type", "behavior_id", "seek_cover", "suppression_response", "formation_preference", "retreat_hp_threshold_bp", "retreat_morale_threshold_bp"], "properties": {"group_type": {"enum": ["melee_line", "ranged_line", "siege_group", "cavalry_wing", "naval_fleet", "air_wing", "cyber_cell"]}, "behavior_id": {"$ref": "common.schema.json#/$defs/record_id"}, "seek_cover": {"type": "boolean"}, "suppression_response": {"enum": ["hold", "retreat", "flank"]}, "formation_preference": {"enum": ["line", "column", "wedge", "dispersed"]}, "retreat_hp_threshold_bp": {"type": "integer", "minimum": 0, "maximum": 10000}, "retreat_morale_threshold_bp": {"type": "integer", "minimum": 0, "maximum": 10000}}}},
    "difficulty_params": {"type": "object", "additionalProperties": false, "required": ["decision_period_ticks", "reaction_latency_ticks", "micro_quality_bp", "build_order_variance_bp", "scouting_thoroughness_bp", "counter_reaction_delay_ticks"], "properties": {"decision_period_ticks": {"type": "integer", "minimum": 1, "maximum": 1000000}, "reaction_latency_ticks": {"type": "integer", "minimum": 1, "maximum": 1000000}, "micro_quality_bp": {"type": "integer", "minimum": 0, "maximum": 10000}, "build_order_variance_bp": {"type": "integer", "minimum": 0, "maximum": 10000}, "scouting_thoroughness_bp": {"type": "integer", "minimum": 0, "maximum": 10000}, "counter_reaction_delay_ticks": {"type": "integer", "minimum": 1, "maximum": 1000000}}}, "performance_lod": {"type": "object", "additionalProperties": false, "required": ["min_decision_period_ticks", "cache_ttl_ticks"], "properties": {"min_decision_period_ticks": {"type": "integer", "minimum": 1, "maximum": 1000000}, "cache_ttl_ticks": {"type": "integer", "minimum": 1, "maximum": 1000000}}}, "provenance": {"$ref": "common.schema.json#/$defs/provenance"}
  }
}
