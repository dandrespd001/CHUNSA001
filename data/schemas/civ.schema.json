{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "chunsa/civ.schema.json", "title": "civ v1",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "id", "historical_window", "epoch_window", "region_key", "display_name_key", "description_key", "gameplay_verb", "playable_periods", "institutions", "social_tensions", "unit_ids", "building_ids", "tech_ids", "art_rule_keys", "review_roles", "provenance"],
  "properties": {
    "schema_version": {"const": 1}, "id": {"$ref": "common.schema.json#/$defs/record_id"}, "historical_window": {"type": "object", "additionalProperties": false, "required": ["start_year", "end_year"], "properties": {"start_year": {"$ref": "common.schema.json#/$defs/year"}, "end_year": {"$ref": "common.schema.json#/$defs/year"}}}, "epoch_window": {"$ref": "common.schema.json#/$defs/epoch_window"}, "region_key": {"$ref": "common.schema.json#/$defs/localization_key"}, "display_name_key": {"$ref": "common.schema.json#/$defs/localization_key"}, "description_key": {"$ref": "common.schema.json#/$defs/localization_key"},
    "gameplay_verb": {"type": "object", "additionalProperties": false, "required": ["id", "name_key", "description_key"], "properties": {"id": {"$ref": "common.schema.json#/$defs/record_id"}, "name_key": {"$ref": "common.schema.json#/$defs/localization_key"}, "description_key": {"$ref": "common.schema.json#/$defs/localization_key"}}},
    "playable_periods": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["id", "start_year", "end_year", "label_key"], "properties": {"id": {"$ref": "common.schema.json#/$defs/record_id"}, "start_year": {"$ref": "common.schema.json#/$defs/year"}, "end_year": {"$ref": "common.schema.json#/$defs/year"}, "label_key": {"$ref": "common.schema.json#/$defs/localization_key"}}}},
    "institutions": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["id", "name_key", "mechanic_description_key", "cost_or_tension_key", "required_capability_ids"], "properties": {"id": {"$ref": "common.schema.json#/$defs/record_id"}, "name_key": {"$ref": "common.schema.json#/$defs/localization_key"}, "mechanic_description_key": {"$ref": "common.schema.json#/$defs/localization_key"}, "cost_or_tension_key": {"$ref": "common.schema.json#/$defs/localization_key"}, "required_capability_ids": {"$ref": "common.schema.json#/$defs/record_id_set"}}}},
    "social_tensions": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["id", "name_key", "description_key"], "properties": {"id": {"$ref": "common.schema.json#/$defs/record_id"}, "name_key": {"$ref": "common.schema.json#/$defs/localization_key"}, "description_key": {"$ref": "common.schema.json#/$defs/localization_key"}}}},
    "unit_ids": {"$ref": "common.schema.json#/$defs/record_id_set"}, "building_ids": {"$ref": "common.schema.json#/$defs/record_id_set"}, "tech_ids": {"$ref": "common.schema.json#/$defs/record_id_set"}, "art_rule_keys": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "common.schema.json#/$defs/localization_key"}}, "review_roles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 64}}, "provenance": {"$ref": "common.schema.json#/$defs/provenance"}
  }
}
