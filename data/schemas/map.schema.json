{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "chunsa/map.schema.json", "title": "map v1",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "id", "display_name_key", "width_tiles", "height_tiles", "biome", "terrain_rle", "cost_rle", "resource_spawns", "starting_positions", "recommended_epoch_window", "provenance"],
  "properties": {
    "schema_version": {"const": 1}, "id": {"$ref": "common.schema.json#/$defs/record_id"}, "display_name_key": {"$ref": "common.schema.json#/$defs/localization_key"}, "width_tiles": {"type": "integer", "minimum": 1, "maximum": 8192}, "height_tiles": {"type": "integer", "minimum": 1, "maximum": 8192}, "biome": {"enum": ["plain", "desert", "arctic", "tropical", "island", "archipelago", "continental", "basin", "canyon", "jungle", "tundra"]},
    "terrain_rle": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["terrain", "run"], "properties": {"terrain": {"enum": ["plain", "water", "forest", "hill", "mountain", "desert", "swamp", "jungle", "snow", "city"]}, "run": {"type": "integer", "minimum": 1, "maximum": 4294967295}}}}, "cost_rle": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["cost", "run"], "properties": {"cost": {"type": "integer", "minimum": 1, "maximum": 255}, "run": {"type": "integer", "minimum": 1, "maximum": 4294967295}}}},
    "resource_spawns": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["kind", "id", "x_millitiles", "y_millitiles", "amount"], "properties": {"kind": {"enum": ["resource", "material"]}, "id": {"type": "string"}, "x_millitiles": {"type": "integer", "minimum": 0, "maximum": 2147483647}, "y_millitiles": {"type": "integer", "minimum": 0, "maximum": 2147483647}, "amount": {"type": "integer", "minimum": 1, "maximum": 1000000}}}}, "starting_positions": {"type": "array", "maxItems": 8, "items": {"type": "object", "additionalProperties": false, "required": ["slot", "x_millitiles", "y_millitiles"], "properties": {"slot": {"type": "integer", "minimum": 0, "maximum": 7}, "x_millitiles": {"type": "integer", "minimum": 0, "maximum": 2147483647}, "y_millitiles": {"type": "integer", "minimum": 0, "maximum": 2147483647}}}},
    "recommended_epoch_window": {"$ref": "common.schema.json#/$defs/epoch_window"}, "provenance": {"$ref": "common.schema.json#/$defs/provenance"}
  }
}
