{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "chunsa/building.schema.json", "title": "building v1",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "id", "civ_id", "display_name_key", "description_key", "epoch_window", "kind", "footprint", "stats", "constructible", "resource_costs", "build_time_ticks", "trains", "researches", "required_capabilities", "grants_capabilities", "recipes", "playable_period_ids", "availability_mode", "provenance"],
  "properties": {
    "schema_version": {"const": 1}, "id": {"$ref": "common.schema.json#/$defs/record_id"}, "civ_id": {"$ref": "common.schema.json#/$defs/record_id"}, "display_name_key": {"$ref": "common.schema.json#/$defs/localization_key"}, "description_key": {"$ref": "common.schema.json#/$defs/localization_key"}, "epoch_window": {"$ref": "common.schema.json#/$defs/epoch_window"},
    "kind": {"enum": ["economic", "military", "civic", "infrastructure", "dropoff", "research", "housing", "wonder"]},
    "footprint": {"type": "object", "additionalProperties": false, "required": ["width_cells", "height_cells", "blocks_movement"], "properties": {"width_cells": {"type": "integer", "minimum": 1, "maximum": 32}, "height_cells": {"type": "integer", "minimum": 1, "maximum": 32}, "blocks_movement": {"type": "boolean"}}},
    "stats": {"type": "object", "additionalProperties": false, "required": ["hp"], "properties": {"hp": {"type": "integer", "minimum": 1, "maximum": 10000000}}}, "constructible": {"type": "boolean"},
    "resource_costs": {"$ref": "common.schema.json#/$defs/resource_costs"}, "material_costs": {"$ref": "common.schema.json#/$defs/material_costs"}, "build_time_ticks": {"type": "integer", "minimum": 0, "maximum": 10000000}, "dropoff_resources": {"$ref": "common.schema.json#/$defs/resource_set"}, "trains": {"$ref": "common.schema.json#/$defs/record_id_set"}, "researches": {"$ref": "common.schema.json#/$defs/record_id_set"}, "required_capabilities": {"$ref": "common.schema.json#/$defs/record_id_set"}, "grants_capabilities": {"$ref": "common.schema.json#/$defs/record_id_set"},
    "recipes": {"type": "array", "uniqueItems": true, "items": {"type": "object", "additionalProperties": false, "required": ["id", "input_resource_costs", "input_material_costs", "output_material_id", "output_amount", "duration_ticks"], "properties": {"id": {"$ref": "common.schema.json#/$defs/record_id"}, "input_resource_costs": {"$ref": "common.schema.json#/$defs/resource_costs"}, "input_material_costs": {"$ref": "common.schema.json#/$defs/material_costs"}, "output_material_id": {"$ref": "common.schema.json#/$defs/record_id"}, "output_amount": {"type": "integer", "minimum": 1, "maximum": 1000000}, "duration_ticks": {"type": "integer", "minimum": 1, "maximum": 10000000}}}},
    "playable_period_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "common.schema.json#/$defs/record_id"}}, "availability_mode": {"enum": ["historical", "counterfactual"]}, "counterfactual_label_key": {"$ref": "common.schema.json#/$defs/localization_key"}, "provenance": {"$ref": "common.schema.json#/$defs/provenance"}
  },
  "allOf": [
    {"if": {"properties": {"availability_mode": {"const": "historical"}}}, "then": {"not": {"required": ["counterfactual_label_key"]}}}, {"if": {"properties": {"availability_mode": {"const": "counterfactual"}}}, "then": {"required": ["counterfactual_label_key"]}},
    {"if": {"properties": {"kind": {"const": "dropoff"}}}, "then": {"required": ["dropoff_resources"], "properties": {"dropoff_resources": {"minItems": 1}}}},
    {"if": {"properties": {"constructible": {"const": true}}}, "then": {"properties": {"build_time_ticks": {"minimum": 1}}, "anyOf": [{"properties": {"resource_costs": {"$ref": "common.schema.json#/$defs/positive_resource_costs"}}}, {"required": ["material_costs"], "properties": {"material_costs": {"minItems": 1}}}]}, "else": {"properties": {"build_time_ticks": {"const": 0}, "resource_costs": {"maxProperties": 0}, "material_costs": {"maxItems": 0}}}}
  ]
}
